{
  "Logging": {
    "LogLevel": {
      "Default": "Trace",
      "Microsoft.AspNetCore": "Trace"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "Microsoft": "Verbose",
        "Microsoft.Hosting.Lifetime": "Verbose"
      }
    },
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/applog-prod-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "GamestoreDb": "Server=(localdb)\\MSSQLLocalDB;Database=GamestoreDB;MultipleActiveResultSets=true"
  },
  "NorthwindDb": {
    "ConnectionString": "mongodb://127.0.0.1:27017",
    "DatabaseName": "Northwind"
  },

  "PaymentSettings": {
    "Methods": [
      {
        "Title": "Bank",
        "Description": "Pay directly via bank transfer. Valid for 3 days.",
        "ImageUrl": "https://cdn-icons-png.flaticon.com/512/2830/2830284.png"
      },
      {
        "Title": "IBox terminal",
        "Description": "Pay using self-service terminals.",
        "ImageUrl": "https://cdn-icons-png.flaticon.com/512/2331/2331943.png"
      },
      {
        "Title": "Visa",
        "Description": "Pay instantly with your card.",
        "ImageUrl": "https://cdn-icons-png.flaticon.com/512/349/349221.png"
      }
    ]
  },
  "PaymentOptions": {
    "InvoiceValidityDays": 3
  },
  "ApiSettings": {
    "PaymentService": "http://localhost:5000"
  }
}
